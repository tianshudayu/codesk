<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/codesk_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/launcher_card"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/brandLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textAllCaps="true"
                android:textColor="@color/codesk_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bridgeStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/bridge_status_line"
                android:textColor="@color/codesk_text_soft"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/cloudStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/cloud_status_line"
                android:textColor="@color/codesk_text_soft"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/stateEyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="@string/unpaired_eyebrow"
                android:textAllCaps="true"
                android:textColor="@color/codesk_muted"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/stateTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/unpaired_title"
                android:textColor="@color/codesk_text"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/stateBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:text="@string/unpaired_body"
                android:textColor="@color/codesk_text_soft"
                android:textSize="15sp" />

            <ProgressBar
                android:id="@+id/progress"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/pairSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/pairCodeInput"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/launcher_input"
                    android:gravity="center"
                    android:hint="@string/pair_code_hint"
                    android:inputType="number"
                    android:letterSpacing="0.18"
                    android:maxLength="6"
                    android:paddingHorizontal="18dp"
                    android:textColor="@color/codesk_text"
                    android:textColorHint="@color/codesk_text_soft"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/pairButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/launcher_primary_button"
                    android:backgroundTint="@null"
                    android:text="@string/pair_go"
                    android:textColor="@color/codesk_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/pairStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/pair_code_note"
                android:textColor="@color/codesk_text_soft"
                android:textSize="13sp" />

            <Button
                android:id="@+id/primaryButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/launcher_primary_button"
                android:backgroundTint="@null"
                android:text="@string/open_codesk"
                android:textColor="@color/codesk_text"
                android:visibility="gone" />

            <Button
                android:id="@+id/secondaryButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/launcher_secondary_button"
                android:backgroundTint="@null"
                android:text="@string/refresh_status"
                android:textColor="@color/codesk_text"
                android:visibility="gone" />

            <Button
                android:id="@+id/disconnectButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/launcher_secondary_button"
                android:backgroundTint="@null"
                android:text="@string/disconnect_device"
                android:textColor="@color/codesk_text"
                android:visibility="gone" />

            <Button
                android:id="@+id/downloadWindowsButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/launcher_secondary_button"
                android:backgroundTint="@null"
                android:text="@string/download_windows"
                android:textColor="@color/codesk_text" />

            <TextView
                android:id="@+id/statusDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/codesk_text_soft"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
